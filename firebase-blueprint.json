{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin_sales", "admin_packing", "admin_production", "super_admin"] },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "photoURL": { "type": "string" },
        "attendanceScore": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product catalog item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "stock": { "type": "integer" },
        "features": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "enabled": { "type": "boolean" },
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "integer" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Diproses", "Dikemas", "Dikirim", "Selesai"] },
        "address": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "trackingNumber": { "type": "string" }
      },
      "required": ["customerId", "items", "total", "status", "address"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "Raw material or supply item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "minStock": { "type": "number" }
      },
      "required": ["name", "category", "stock", "unit", "minStock"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Attendance record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Hadir", "Izin", "Sakit"] },
        "photoUrl": { "type": "string" },
        "reason": { "type": "string" },
        "sickNoteUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/pending_users/{userId}": {
      "schema": "User",
      "description": "Users awaiting approval"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Inventory of raw materials"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records"
    }
  }
}
