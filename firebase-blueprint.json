{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin_sales", "admin_packing", "admin_production", "super_admin"] },
        "address": { "type": "string" },
        "district": { "type": "string" },
        "postalCode": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "photoURL": { "type": "string" },
        "attendanceScore": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product catalog item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "stock": { "type": "integer" },
        "weight": { "type": "number", "description": "Weight per product in grams" },
        "discountPrice": { "type": "number" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "promoLabel": { "type": "string" },
        "isBundle": { "type": "boolean" },
        "bundleItems": { "type": "array", "items": { "type": "string" } },
        "features": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "enabled": { "type": "boolean" },
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "PaymentMethod": {
      "title": "PaymentMethod",
      "description": "Payment method configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["bank", "dana"] },
        "name": { "type": "string" },
        "accountNumber": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "barcodeUrl": { "type": "string" },
        "iconUrl": { "type": "string" }
      },
      "required": ["type", "name"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "integer" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Diproses", "Dikemas", "Dikirim", "Selesai"] },
        "address": { "type": "string" },
        "shippingCost": { "type": "number" },
        "shippingDiscountAmount": { "type": "number" },
        "shippingPromoId": { "type": "string" },
        "totalWeight": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "paymentProofUrl": { "type": "string" },
        "approvalStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "trackingNumber": { "type": "string" }
      },
      "required": ["customerId", "items", "total", "status", "address"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "Raw material or supply item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "minStock": { "type": "number" }
      },
      "required": ["name", "category", "stock", "unit", "minStock"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Attendance record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Hadir", "Izin", "Sakit"] },
        "photoUrl": { "type": "string" },
        "reason": { "type": "string" },
        "sickNoteUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "status"]
    },
    "PromoCode": {
      "title": "PromoCode",
      "description": "Promotional discount code",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "minPurchase": { "type": "number" },
        "maxDiscount": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date" },
        "usageLimit": { "type": "integer" },
        "usageCount": { "type": "integer" },
        "isActive": { "type": "boolean" }
      },
      "required": ["code", "discountType", "discountValue", "isActive"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Chat conversation between customer and admin",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageTime": { "type": "string", "format": "date-time" },
        "unreadAdmin": { "type": "integer" },
        "unreadUser": { "type": "integer" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "lastMessage", "lastMessageTime", "unreadAdmin", "unreadUser", "updatedAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Individual chat message",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderRole": { "type": "string", "enum": ["customer", "admin_sales"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "senderRole", "createdAt"]
    },
    "ShippingPromo": {
      "title": "ShippingPromo",
      "description": "Shipping discount or free shipping configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "minPurchase": { "type": "number" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed", "free"] },
        "discountValue": { "type": "number" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "minPurchase", "discountType", "isActive"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/pending_users/{userId}": {
      "schema": "User",
      "description": "Users awaiting approval"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Inventory of raw materials"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records"
    },
    "/promo_codes/{promoId}": {
      "schema": "PromoCode",
      "description": "Promotional codes"
    },
    "/payment_methods/{methodId}": {
      "schema": "PaymentMethod",
      "description": "Available payment methods"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a chat session"
    },
    "/shipping_promos/{promoId}": {
      "schema": "ShippingPromo",
      "description": "Shipping promotions"
    }
  }
}
